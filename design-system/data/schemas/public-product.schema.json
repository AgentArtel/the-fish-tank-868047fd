{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thefishtank.com/schemas/public-product.schema.json",
  "title": "PublicProduct",
  "description": "Website-facing product, projected from the workspace public_products read model. See DATA_MODEL.md for the column mapping.",
  "type": "object",
  "required": ["id", "slug", "name", "type", "price", "availability", "images"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "description": "inventory_items.id (uuid)" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "scientificName": { "type": ["string", "null"] },
    "type": { "type": "string", "enum": ["coral", "fish", "invert", "supply"] },
    "category": { "type": ["string", "null"] },
    "subcategory": { "type": ["string", "null"] },
    "price": { "type": "number", "minimum": 0, "description": "USD dollars" },
    "compareAtPrice": { "type": ["number", "null"], "minimum": 0, "description": "Original price; render strike-through + % OFF only when > price" },
    "currency": { "type": "string", "default": "USD" },
    "availability": { "type": "string", "enum": ["available", "on_hold", "sold", "coming_soon"] },
    "isWysiwyg": { "type": "boolean", "default": false, "description": "Photo-accuracy promise (is_wysiwyg) set at intake — the photographed specimen is the one that ships. Drives the badge + catalog filter." },
    "isHouseLine": { "type": "boolean", "default": false, "description": "Public in-house brand flag (is_house_line). Never the wholesale vendor." },
    "careLevel": { "type": ["string", "null"], "enum": ["Beginner", "Intermediate", "Expert", null] },
    "reefSafe": { "type": ["string", "null"], "enum": ["Safe", "Caution", "Not reef safe", null] },
    "originRegion": { "type": ["string", "null"] },
    "size": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "careNotes": { "type": ["string", "null"] },
    "tankLocation": { "type": ["string", "null"] },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url"],
        "additionalProperties": false,
        "properties": {
          "url": { "type": "string", "format": "uri-reference" },
          "alt": { "type": ["string", "null"] },
          "isPrimary": { "type": "boolean", "default": false },
          "view": { "type": "string", "enum": ["daylight", "actinic", "video_still", "other"], "default": "daylight" }
        }
      }
    },
    "badges": {
      "type": "array",
      "items": { "type": "string", "enum": ["New", "WYSIWYG", "Sale", "Staff Pick", "Aquacultured", "Last One"] }
    },
    "rating": {
      "type": ["object", "null"],
      "properties": { "value": { "type": "number", "minimum": 0, "maximum": 5 }, "count": { "type": "integer", "minimum": 0 } }
    },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
